# URL do webhook do n8n (ver n8n-workflow-guia.md)
# SEM prefixo VITE_ de propósito — assim ela só existe no servidor (função em api/),
# nunca é enviada ao navegador. Configure isso na Vercel em Project Settings > Environment Variables.
N8N_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/sieg-social-check

# Opcional: um segredo compartilhado com o n8n (Header Auth no node Webhook) pra autenticar as chamadas
N8N_SECRET=
